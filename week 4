    height: 100%;
    margin: 1;
  }
  body {
    display:flex;
    flex-direction: column;
  }

  .row1 {
    flex: 1;
    background-color: #ff9999; 
  }

  .row2 {
    flex: 1;
    display: flex;
  }

  .col {
    flex: 1;
  }
  .col1 {
    background-color: #99ccff; 
  }
  .col2 {
    background-color: #99ff99; 
  }
 
</style>
</head>

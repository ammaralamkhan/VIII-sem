<!DOCTYPE html>
<html>
<head>
<title>Two Frames</title>
<style>
body{font-family:Arial;margin:0}
.container{display:flex;height:100vh}
.left{width:30%;background:#f0f0f0;padding:20px}
.right{width:70%;padding:20px}
a{display:block;margin:10px 0;color:blue;cursor:pointer}
input{margin:10px;padding:8px;width:200px}
button{padding:8px 15px}
#result{margin-top:20px;font-weight:bold}
</style>
</head>
<body>

<div class="container">
<div class="left">
<h3>Forms</h3>
<a onclick="loadForm(1)">Form 1</a>
<a onclick="loadForm(2)">Form 2</a>
</div>

<div class="right">
<div id="formArea"></div>
<div id="result"></div>
</div>
</div>

<script>
function loadForm(n){
if(n===1){
document.getElementById("formArea").innerHTML=
'<h3>Form 1</h3>\
<input id="name" placeholder="Enter Name"><br>\
<button onclick="submitForm1()">Submit</button>';
}
else{
document.getElementById("formArea").innerHTML=
'<h3>Form 2</h3>\
<input id="age" type="number" placeholder="Enter Age"><br>\
<button onclick="submitForm2()">Submit</button>';
}
document.getElementById("result").innerHTML="";
}

function submitForm1(){
let name=document.getElementById("name").value;
if(name==="" || name==Number){
alert("Name required");
return;
}
document.getElementById("result").innerHTML="Name: "+name;
}

function submitForm2(){
let age=document.getElementById("age").value;
if(age==="" || age<=0){
alert("Valid age required");
return;
}
document.getElementById("result").innerHTML="Age: "+age;
}
</script>

</body>
</html>
